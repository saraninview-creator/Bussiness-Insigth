# ── Supabase (required for cloud API) ─────────────────────────────────────────
# Get these from https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ── Frontend (optional) ────────────────────────────────────────────────────────
# Leave blank in monorepo deploys (Vercel routes /api/* automatically).
# Set to your Railway/Render backend URL for split-deploy setups:
# VITE_API_URL=https://datanarrate-api.up.railway.app
VITE_API_URL=
