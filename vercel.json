{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)",       "dest": "/api/index.py" },
    { "src": "/upload",         "dest": "/api/index.py" },
    { "src": "/upload/(.*)",    "dest": "/api/index.py" },
    { "src": "/status/(.*)",    "dest": "/api/index.py" },
    { "src": "/result/(.*)",    "dest": "/api/index.py" },
    { "src": "/health",         "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)",           "dest": "/index.html" }
  ]
}
